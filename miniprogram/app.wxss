/* ====== 全局样式变量 ====== */
page {
  --bg: #0f0f23;
  --surface: #1a1a2e;
  --surface2: #16213e;
  --border: #2a2a4a;
  --text: #e0e0e0;
  --text2: #c0c0c0;
  --muted: #888;
  --accent: #00d4aa;
  --accent2: #7c3aed;
  --red: #ff6b6b;
  --tag-green-bg: #064e3b;
  --tag-green-text: #34d399;
  --tag-gray-bg: #374151;
  --tag-gray-text: #9ca3af;
  --tag-blue-bg: #1e3a5f;
  --tag-blue-text: #60a5fa;
  --tag-purple-bg: #3b1f6e;
  --tag-purple-text: #a78bfa;
  --radius: 12rpx;

  background: var(--bg);
  color: var(--text);
  font-size: 28rpx;
  line-height: 1.6;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  box-sizing: border-box;
  padding-bottom: 40rpx;
}

/* ====== 通用原子样式 ====== */
.container {
  padding: 24rpx;
}

.panel {
  background: var(--surface);
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid var(--border);
}

.panel-heading {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.panel-heading-title {
  font-size: 32rpx;
  font-weight: 700;
}

.badge {
  display: inline-block;
  background: var(--surface2);
  color: var(--accent);
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  margin-left: 8rpx;
}

.arrow-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--surface2);
  border: 2rpx solid var(--border);
  color: var(--text);
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.arrow-btn.dimmed {
  opacity: 0.3;
}

/* ====== Toast ====== */
.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: var(--accent);
  color: #000;
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  z-index: 9999;
  opacity: 0;
  transition: opacity 0.3s;
  pointer-events: none;
}

.toast.show {
  opacity: 1;
}
