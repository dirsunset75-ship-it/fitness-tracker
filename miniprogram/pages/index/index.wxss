/* ================================================================
   首页样式
   ================================================================ */

/* ====== 头部 ====== */
.hero {
  padding: 32rpx 24rpx;
  margin-bottom: 24rpx;
}

.eyebrow {
  font-size: 24rpx;
  color: var(--accent);
  letter-spacing: 4rpx;
  margin-bottom: 8rpx;
}

.hero-title {
  font-size: 48rpx;
  font-weight: 800;
  margin-bottom: 8rpx;
}

.subtitle {
  font-size: 24rpx;
  color: var(--muted);
}

.today-pill {
  display: inline-block;
  margin-top: 16rpx;
  background: var(--accent);
  color: #000;
  font-size: 24rpx;
  padding: 8rpx 28rpx;
  border-radius: 30rpx;
  font-weight: 600;
}

/* ====== 面板 ====== */
.day-switcher {
  display: flex;
  align-items: center;
}

.day-label {
  font-size: 26rpx;
  color: var(--text2);
  padding: 0 12rpx;
  white-space: nowrap;
  text-align: center;
  max-width: 400rpx;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ====== 计划卡片 ====== */
.plan-card {
  background: var(--surface2);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.plan-card-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.plan-detail {
  font-size: 26rpx;
  color: var(--text2);
  margin-bottom: 8rpx;
  line-height: 1.6;
}

.bold {
  font-weight: 600;
}

.exercise-list {
  margin: 16rpx 0;
}

.exercise-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.ex-name {
  font-size: 26rpx;
  flex: 1;
}

.ex-detail {
  font-size: 24rpx;
  color: var(--accent);
  white-space: nowrap;
  margin-left: 16rpx;
}

.mode-badge {
  background: var(--accent2);
  color: #fff;
}

/* 饮食 */
.diet-list {
  margin: 12rpx 0;
}

.diet-item {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.diet-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  width: 48rpx;
}

.diet-label {
  font-size: 26rpx;
  font-weight: 600;
  min-width: 80rpx;
  margin-right: 12rpx;
}

.diet-val {
  flex: 1;
  font-size: 26rpx;
  color: var(--text2);
  background: transparent;
  border: 1rpx solid transparent;
  border-radius: 8rpx;
  padding: 6rpx 12rpx;
}

.diet-val:focus {
  border-color: var(--accent);
  background: rgba(0, 212, 170, 0.05);
}

/* 目标 */
.goals-card {
  background: linear-gradient(135deg, #16213e, #1a2744);
}

.goals-row {
  display: flex;
  justify-content: space-around;
}

.goal-item {
  text-align: center;
}

.goal-val {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--accent);
}

.goal-sub {
  font-size: 22rpx;
  color: var(--muted);
}

.goal-label {
  font-size: 24rpx;
  color: var(--muted);
  margin-top: 4rpx;
}

/* ====== 统计 ====== */
.stats-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -8rpx;
}

.stat-card {
  width: calc(33.33% - 16rpx);
  margin: 8rpx;
  background: var(--surface2);
  border-radius: 16rpx;
  padding: 24rpx 8rpx;
  text-align: center;
  box-sizing: border-box;
}

.stat-num {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--accent);
}

.stat-label {
  font-size: 20rpx;
  color: var(--muted);
  display: block;
  margin-top: 6rpx;
}

.vs-last-week {
  margin-top: 20rpx;
  padding: 16rpx;
  background: var(--surface2);
  border-radius: 12rpx;
  font-size: 26rpx;
  text-align: center;
}

.text-muted {
  color: var(--muted);
}

/* ====== 日历 ====== */
.calendar-grid {
  display: flex;
  flex-wrap: wrap;
}

.cal-cell {
  width: calc(100% / 7);
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  position: relative;
}

.cal-header {
  font-weight: 700;
  color: var(--muted);
  font-size: 22rpx;
  height: 60rpx;
  aspect-ratio: auto;
}

.cal-empty {
  visibility: hidden;
}

.cal-day {
  border-radius: 12rpx;
  box-sizing: border-box;
}

.cal-num {
  font-size: 24rpx;
  font-weight: 600;
}

.cal-today {
  background: var(--accent);
  color: #000;
}

.cal-today .cal-num {
  font-weight: 800;
}

.cal-done {
  border: 3rpx solid var(--accent);
}

.cal-has-record {
  border: 2rpx dashed var(--accent2);
}

.cal-sub {
  font-size: 16rpx;
  line-height: 1.3;
  color: var(--text2);
  text-align: center;
}

.cal-protein {
  color: var(--accent);
}

.cal-guitar {
  color: #fbbf24;
}

.calendar-legend {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: var(--muted);
  text-align: center;
}

/* ====== 表单 ====== */
.form-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -8rpx;
}

.form-item {
  margin: 8rpx;
}

.form-item:first-child,
.form-item:nth-child(2) {
  width: calc(50% - 16rpx);
}

.form-item:nth-child(3),
.form-item:nth-child(4) {
  width: calc(50% - 16rpx);
}

.form-item:nth-child(5) {
  width: calc(50% - 16rpx);
}

.form-label {
  font-size: 24rpx;
  color: var(--muted);
  margin-bottom: 6rpx;
}

.form-item input,
.form-item .picker-display {
  background: var(--surface2);
  border: 2rpx solid var(--border);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  color: var(--text);
  width: 100%;
  box-sizing: border-box;
}

.form-item input:focus {
  border-color: var(--accent);
}

.picker-display {
  color: var(--text2);
}

.form-section {
  margin-top: 24rpx;
}

.form-section-title {
  font-size: 26rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
  color: var(--text2);
}

.checkbox-group {
  display: flex;
  flex-wrap: wrap;
}

.checkbox-item {
  display: flex;
  align-items: center;
  margin-right: 32rpx;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  min-width: 200rpx;
}

.form-item-row {
  display: flex;
  align-items: center;
  font-size: 26rpx;
}

.kegel-input {
  width: 80rpx !important;
  text-align: center;
  margin: 0 8rpx;
  padding: 8rpx !important;
}

/* 训练表格 */
.training-table {
  background: var(--surface2);
  border-radius: 16rpx;
  overflow: hidden;
}

.tr-row {
  display: flex;
  border-bottom: 1rpx solid var(--border);
  align-items: center;
}

.tr-head {
  background: rgba(0, 0, 0, 0.2);
  font-weight: 700;
}

.tr-name-col {
  flex: 2;
  padding: 14rpx 12rpx;
  font-size: 24rpx;
  color: var(--muted);
  min-width: 0;
}

.tr-name {
  flex: 2;
  min-width: 0;
}

.tr-sets,
.tr-reps {
  flex: 1;
  min-width: 0;
}

.tr-weight {
  flex: 1;
  min-width: 0;
}

.th-input {
  flex: 1;
  min-width: 0;
}

.th-input.th-last {
  flex: 1;
}

.tr-row input,
.th-input {
  background: transparent;
  border: none;
  border-radius: 0;
  color: var(--text);
  font-size: 24rpx;
  padding: 14rpx 8rpx;
  text-align: center;
  min-width: 0;
  width: 100%;
  box-sizing: border-box;
}

.tr-row .tr-name,
.tr-name-col {
  text-align: left;
}

.hint-text {
  font-size: 22rpx;
  color: var(--muted);
  margin-top: 8rpx;
}

/* 备注 */
textarea {
  background: var(--surface2);
  border: 2rpx solid var(--border);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  color: var(--text);
  width: 100%;
  box-sizing: border-box;
  min-height: 120rpx;
}

/* 提交按钮 */
.primary-btn {
  width: 100%;
  margin-top: 24rpx;
  background: linear-gradient(135deg, #00d4aa, #00b894);
  color: #000;
  font-size: 32rpx;
  font-weight: 700;
  padding: 24rpx;
  border-radius: 16rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(0, 212, 170, 0.25);
}

/* ====== 历史记录 ====== */
.empty-text {
  text-align: center;
  color: var(--muted);
  padding: 60rpx 0;
  font-size: 28rpx;
}

.history-card {
  background: var(--surface2);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.hc-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.hc-title {
  font-size: 28rpx;
  font-weight: 600;
}

.btn-sm {
  background: var(--border);
  color: var(--text);
  font-size: 22rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  border: none;
}

.meta {
  display: flex;
  flex-wrap: wrap;
  font-size: 24rpx;
  color: var(--text2);
  margin-bottom: 10rpx;
}

.meta text {
  margin-right: 20rpx;
  margin-bottom: 6rpx;
}

.badges-row {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 10rpx;
}

.tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-right: 10rpx;
  margin-bottom: 6rpx;
}

.tag-green {
  background: var(--tag-green-bg);
  color: var(--tag-green-text);
}

.tag-gray {
  background: var(--tag-gray-bg);
  color: var(--tag-gray-text);
}

.tag-blue {
  background: var(--tag-blue-bg);
  color: var(--tag-blue-text);
}

.tag-purple {
  background: var(--tag-purple-bg);
  color: var(--tag-purple-text);
}

.note-text {
  font-size: 24rpx;
  color: var(--muted);
  margin-top: 8rpx;
}

/* ====== 执行要点 ====== */
.tips-toggle {
  font-size: 28rpx;
  font-weight: 700;
  padding: 12rpx 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.tip-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.tip-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--accent);
  margin-bottom: 6rpx;
}

.tip-body {
  font-size: 24rpx;
  color: var(--text2);
  line-height: 1.7;
}
